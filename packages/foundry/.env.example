# Template for Foundry environment variables.
# Copy to `.env` and fill values; never commit secrets.

# RPC configuration (set the one you actually use)
MAINNET_RPC_URL=https://mainnet.example
BASE_RPC_URL=https://base-mainnet.example
SEPOLIA_RPC_URL=https://sepolia.example
ALCHEMY_API_KEY=your-alchemy-key

# Deploy keys
DEPLOYER_PRIVATE_KEY=0xabc123...
CHAIN_ID=1

# External EulerEarn vaults (addresses for deployments)
EULER_EARN_VAULT_USDC=0x0000000000000000000000000000000000000000
EULER_EARN_VAULT_USDT=0x0000000000000000000000000000000000000000

# Explorers
ETHERSCAN_API_KEY=your-etherscan-key

# Localhost keystore used by scaffold scripts (optional)
LOCALHOST_KEYSTORE_ACCOUNT=scaffold-eth-default
