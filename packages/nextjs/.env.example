# Template for Next.js environment variables.
# Copy to `.env.local` for local dev; keep secrets out of Git.

# Wallet/infra
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
NEXT_PUBLIC_ALCHEMY_API_KEY=
NEXT_PUBLIC_RPC_URL=https://mainnet.example
NEXT_PUBLIC_CHAIN_ID=1

# EarnGrid contract configuration
NEXT_PUBLIC_EARNTOKEN_SYMBOL=USDC
NEXT_PUBLIC_EARNGRID_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_EULER_EARN_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
